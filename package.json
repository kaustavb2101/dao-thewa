{
  "name": "DaoThewa",
  "version": "1.0.0",
  "private": true,
  "description": "ดาวเทวา — Thai Horology × Astrology App",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "build:ios": "react-native build-ios --configuration Release",
    "build:android": "react-native build-android --mode release"
  },
  "dependencies": {
    "@notifee/react-native": "^7.8.2",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@shopify/flash-list": "^1.6.3",
    "@tanstack/react-query": "^5.24.1",
    "astronomy-engine": "^2.1.19",
    "axios": "^1.6.8",
    "luxon": "^3.4.4",
    "react": "18.2.0",
    "react-native": "0.73.4",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-purchases": "^7.26.1",
    "react-native-reanimated": "3.7.2",
    "react-native-safe-area-context": "^4.9.0",
    "react-native-screens": "3.29.0",
    "react-native-svg": "14.1.0",
    "react-native-vector-icons": "^10.0.3",
    "react-native-watch-connectivity": "^1.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native/babel-preset": "^0.73.21",
    "@react-native/eslint-config": "^0.73.2",
    "@react-native/metro-config": "^0.73.5",
    "@react-native/typescript-config": "^0.73.1",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.12",
    "@types/luxon": "^3.4.2",
    "@types/react": "^18.2.6",
    "@types/react-native": "^0.73.0",
    "@types/react-native-vector-icons": "^6.4.18",
    "eslint": "^8.19.0",
    "jest": "^29.7.0",
    "react-native-svg-transformer": "^1.5.3",
    "ts-jest": "^29.4.6",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": [
        "ts-jest",
        {
          "tsconfig": {
            "jsx": "react-native"
          }
        }
      ]
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(react-native|@react-native|@react-navigation|react-native-reanimated|react-native-svg|astronomy-engine)/)"
    ],
    "testMatch": [
      "**/tests/**/*.test.ts",
      "**/tests/**/*.test.tsx"
    ]
  },
  "engines": {
    "node": ">=18"
  }
}
